# ============================================
# Digital Mate — Configuration
# Copy this file to .env and fill in your values
# ============================================

# === LLM Configuration (required) ===
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o
# Optional: cheaper model for intent routing (defaults to LLM_MODEL if empty)
LLM_ROUTER_MODEL=

# === Telegram Bot (required) ===
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather

# === Notion (optional — enables calendar & campaign features) ===
NOTION_API_KEY=
NOTION_CONTENT_CALENDAR_DB=
NOTION_CAMPAIGN_TRACKER_DB=

# === Web Search (optional — enables Research pillar) ===
# Tavily provides better results with page content.
# Falls back to DuckDuckGo (free) if empty.
TAVILY_API_KEY=

# === Bot Settings ===
# Language: bilingual | en | id
BOT_LANGUAGE=bilingual
BOT_NAME=Digital Mate
# Max conversation turns to keep in session context
MAX_CONVERSATION_TURNS=10
